BRUTEFORCE::

public class Main {
    public static void main(String[] args) {
        int[] arr = {10,5,2,6};
        int target = 100;

        int result = prd(arr, target);
        System.out.println(result);
    }

    static int prd(int[] arr, int target) {
        int count = 0;

        for (int i = 0; i < arr.length; i++) {
            int prd = 1;
            prd *= arr[i];
            if (prd >= target) {
                continue;
            }
            else{
                count++;
            }
            for(int j = i+1; j < arr.length; j++) {
               prd *= arr[j];
               if (prd >= target) {
                   break;
               }
               else{
                   count++;
               }
           }
        }
        return count;
    }
}

