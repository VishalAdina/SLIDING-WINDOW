class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        if(k<=1){
            return 0;
        }

        int count = 0;
        int prd = 1;
        int left = 0;
        for(int i = 0; i<nums.length;i++)
        {
            prd *= nums[i];
            while(prd >= k)
            {
                prd = prd/nums[left];
                left++;
            }

            count += (i-left) + 1;
        }
        return count;
    }
}
